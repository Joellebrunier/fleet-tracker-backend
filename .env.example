# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fleet-tracker
DIRECT_URL=postgresql://user:password@localhost:5432/fleet-tracker

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis/Upstash
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=3600

# GPS Providers
FLESPI_TOKEN=your-flespi-api-token
FLESPI_MQTT_HOST=mqtt.flespi.io
FLESPI_MQTT_PORT=8883

ECHOES_API_URL=https://api.echoes.com
ECHOES_API_KEY=your-echoes-api-key

UBIWAN_API_URL=https://api.ubiwan.com
UBIWAN_API_KEY=your-ubiwan-api-key

KEEPTRACE_API_URL=https://api.keeptrace.com
KEEPTRACE_API_KEY=your-keeptrace-api-key

# Mapbox
MAPBOX_TOKEN=your-mapbox-token

# Logging
LOG_LEVEL=debug
